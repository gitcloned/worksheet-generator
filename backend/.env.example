GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_GENAI_USE_VERTEXAI=false
APP_NAME=ai-practice-mvp

# Supabase PostgreSQL connection string (from Supabase project -> Settings -> Database)
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# Supabase JWT secret (from Supabase project -> Settings -> API -> JWT Secret)
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Comma-separated list of allowed frontend origins (leave blank for localhost defaults)
ALLOWED_ORIGINS=

# Frontend base URL for generating assignment links
FRONTEND_BASE_URL=http://localhost:5173
