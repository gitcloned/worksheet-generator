# Backend API base URL.
# In local development, leave this empty — Vite proxies /api/* to localhost:8000 (see vite.config.ts).
# In production (Vercel), set this to your Render backend URL, e.g. https://your-app.onrender.com
VITE_API_BASE_URL=

# Your Supabase project URL.
# Found in Supabase dashboard → Settings → API → Project URL.
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key — safe to expose in the browser.
# Found in Supabase dashboard → Settings → API → Project API keys → anon (public).
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
